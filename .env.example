# Database
DB_PASSWORD=your_secure_password_here_change_in_production

# Backend Security
SECRET_KEY=your_secret_key_here_minimum_32_characters_change_in_production
JWT_SECRET=your_jwt_secret_here_change_in_production

# Frontend Authentication
NEXTAUTH_SECRET=your_nextauth_secret_here_change_in_production
NEXTAUTH_URL=http://localhost:3000

# OAuth Providers (Optional - configure if using OAuth)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=

# Monitoring (Optional)
GRAFANA_PASSWORD=admin

# Development
DEBUG=true

# Production Settings (uncomment and configure for production)
# DEBUG=false
# CORS_ORIGINS=["https://your-production-domain.com"]
# DATABASE_URL=postgresql+asyncpg://user:password@production-db:5432/mcpforge
# REDIS_URL=redis://production-redis:6379
